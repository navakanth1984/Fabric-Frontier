{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACDLC Tenant Profile",
  "type": "object",
  "properties": {
    "tenant_id": { "type": "string" },
    "name": { "type": "string" },
    "tier": { "type": "string", "enum": ["free", "standard", "enterprise"] },
    "quotas": {
      "type": "object",
      "properties": {
        "daily_tokens": { "type": "integer" },
        "max_concurrent_agents": { "type": "integer" }
      }
    }
  },
  "required": ["tenant_id", "tier", "quotas"]
}
